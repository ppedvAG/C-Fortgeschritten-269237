<Window x:Class="TaskTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow" Height="500" Width="300"
		WindowStartupLocation="CenterScreen">
    <Grid Margin="10,0,10,10">
		<Grid.RowDefinitions>
			<RowDefinition Height="10*"/>
			<RowDefinition/>
			<RowDefinition/>
		</Grid.RowDefinitions>
		<ScrollViewer Name="Scroll">
			<TextBlock Name="Output"/>
		</ScrollViewer>
		<ProgressBar Name="Progress" Grid.Row="1" Margin="0,0,0,5"/>
		<!--GRID -->
		<Grid Grid.Row="2">
			<Grid.ColumnDefinitions>
				<ColumnDefinition/>
				<ColumnDefinition/>
			</Grid.ColumnDefinitions>
			<Button Click="SaveSplitJson" Content="Split Json" Grid.Column="0" Margin="0,0,5,0"/>
			<Button Click="Cancel" Content="Abbrechen" Grid.Column="1" Margin="5,0,0,0"/>
		</Grid>
	</Grid>
</Window>
