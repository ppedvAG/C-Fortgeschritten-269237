<Window x:Class="JsonSplit.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow" Height="500" Width="300">
    <Grid Margin="10,0,10,10">
		<Grid.RowDefinitions>
			<RowDefinition Height="10*"/>
			<RowDefinition/>
			<RowDefinition/>
		</Grid.RowDefinitions>
		<ScrollViewer Name="Scroll">
			<TextBlock Name="Output"/>
		</ScrollViewer>
		<ProgressBar IsIndeterminate="True" Grid.Row="1" Margin="0,0,0,5"/>
		<Button Click="SplitJsonFileAndSaveFiles" Content="Split Json" Grid.Row="2"/>
		</Grid>
</Window>
